# Meson cross file: build DXVK (native mode, SDL3 WSI) for Android arm64-v8a
# on a Linux or macOS host, using the NDK's standalone clang drivers.
# Mirrors meson-arm64-ios-cross.ini.in but targets the Android sysroot.
#
# Generated by cmake/dx8.cmake from the ANDROID_NDK_HOME environment:
#   @ANDROID_TOOLCHAIN_BIN@ -> <ndk>/toolchains/llvm/prebuilt/<host>/bin
#   @ANDROID_API@           -> minimum API level (matches ANDROID_PLATFORM)
#
# libc++ is linked statically into the DXVK libs (-static-libstdc++) so
# libdxvk_d3d8.so/libdxvk_d3d9.so are self-contained: they are dlopen()ed by
# the game at runtime and must not depend on the STL the game process chose.
# SDL3 must be discoverable via PKG_CONFIG_PATH (generated sdl3.pc, see dx8.cmake).

[binaries]
c = '@ANDROID_TOOLCHAIN_BIN@/aarch64-linux-android@ANDROID_API@-clang'
cpp = '@ANDROID_TOOLCHAIN_BIN@/aarch64-linux-android@ANDROID_API@-clang++'
ar = '@ANDROID_TOOLCHAIN_BIN@/llvm-ar'
strip = '@ANDROID_TOOLCHAIN_BIN@/llvm-strip'
pkg-config = 'pkg-config'

[host_machine]
system = 'android'
cpu_family = 'aarch64'
cpu = 'aarch64'
endian = 'little'

[built-in options]
c_args = ['-fPIC']
# VK_ENABLE_BETA_EXTENSIONS: the fbraz3 DXVK fork references
# VK_KHR_portability_subset unconditionally (its MoltenVK heritage), and the
# pinned Vulkan-Headers submodule (v307) still keeps that extension in
# vulkan_beta.h behind this define. Harmless on Android — the extension is
# simply never reported by the driver, so the code paths stay dormant.
cpp_args = ['-fPIC', '-DVK_ENABLE_BETA_EXTENSIONS']
c_link_args = []
cpp_link_args = ['-static-libstdc++']

[properties]
# Host-machine pkg-config lookup dir for the generated SDL3.pc. Env vars
# (PKG_CONFIG_LIBDIR/PKG_CONFIG_PATH) only apply to the BUILD machine in a
# meson cross build; the host machine reads this property instead — without
# it, dependency('SDL3') silently fails and dxvk-native aborts.
pkg_config_libdir = '@DXVK_SDL3_PC_DIR@'
